# =============================================================================
# Variáveis usadas por esta stack Docker (compose, scripts e glue Laravel).
# Mescle no .env do seu projeto e troque {{project-name}} pelo nome do projeto
# (ver README.md › "Substituindo o macro").
# =============================================================================

APP_NAME={{project-name}}
APP_ENV=production                              # local em desenvolvimento
APP_DEBUG=false                                 # true em desenvolvimento
APP_KEY=                                         # gerado pelo ./scripts/deploy <env> --first-deploy
APP_URL=https://{{project-name}}.example.com    # http://{{project-name}}.local em dev

# --- Banco (DB_HOST/REDIS_HOST = nomes de serviço do compose; não altere) ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE={{project-name}}
DB_USERNAME={{project-name}}
DB_PASSWORD=
DB_ROOT_PASSWORD=                                # necessária para backup/restore

# --- Redis ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# --- Drivers (recomendado em produção) ---
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis                           # Horizon exige Redis

# --- Mail (em desenvolvimento, capturado pelo Mailpit) ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Específicas da infra
# =============================================================================

# Versão das imagens de produção — gerenciada pelo ./scripts/deploy. Não editar à mão.
PROJECT_VERSION=1.0.0
# Quantas versões de imagem manter no disco por serviço (para rollback).
PROJECT_VERSIONS_TO_KEEP=5

# Log Viewer (/log-viewer) — HTTP Basic Auth. Defina AMBAS em produção
# (se ficarem vazias: liberado em dev, bloqueado em produção).
LOG_VIEWER_AUTH_USER=
LOG_VIEWER_AUTH_PASSWORD=

# Backups (spatie/laravel-backup)
BACKUP_NOTIFICATION_EMAIL=                       # alertas de falha/saúde (default: MAIL_FROM_ADDRESS)
BACKUP_ARCHIVE_PASSWORD=                         # cifra o .zip do backup (vazio = sem cifrar)
